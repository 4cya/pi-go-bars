# Opencode Go Usage Bars — Local Development Credentials
#
# Copy this file to .env and fill in your actual values.
# The extension auto-detects .env in the working directory.
# No manual sourcing or extra config needed.
#
# ⚠ Never commit .env to git (already in .gitignore)

OPENCODE_GO_WORKSPACE_ID="wrk_YOUR_WORKSPACE_ID"
OPENCODE_GO_AUTH_COOKIE="Fe26.2**YOUR_AUTH_COOKIE"
